{
  "name": "atlas-ai-testops-prototype",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "prebuild": "node scripts/clean-dist.mjs",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "postbuild": "node scripts/copy-hosting.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "lint": "tsc --noEmit",
    "generate:api": "openapi-typescript ../../contracts/openapi.json -o lib/api/schema.d.ts",
    "check:api": "node scripts/check-api-contract.mjs"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "next": "16.2.6",
    "openapi-fetch": "0.17.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "swr": "2.4.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "openapi-typescript": "7.13.0",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
