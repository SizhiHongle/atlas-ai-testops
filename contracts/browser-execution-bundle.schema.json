{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.test/contracts/browser-execution-bundle/0.1/schema.json",
  "$defs": {
    "ActorContract": {
      "additionalProperties": false,
      "description": "Non-secret business-role binding used by one case.",
      "properties": {
        "actorSlot": {
          "maxLength": 80,
          "minLength": 2,
          "pattern": "^[A-Za-z][A-Za-z0-9._:-]{1,159}$",
          "title": "Actorslot",
          "type": "string"
        },
        "roleId": {
          "format": "uuid",
          "title": "Roleid",
          "type": "string"
        },
        "roleKey": {
          "maxLength": 80,
          "minLength": 2,
          "pattern": "^[a-z][a-z0-9._-]{1,79}$",
          "title": "Rolekey",
          "type": "string"
        },
        "roleRevision": {
          "minimum": 1,
          "title": "Rolerevision",
          "type": "integer"
        },
        "capabilities": {
          "default": [],
          "items": {
            "type": "string"
          },
          "maxItems": 64,
          "title": "Capabilities",
          "type": "array"
        }
      },
      "required": [
        "actorSlot",
        "roleId",
        "roleKey",
        "roleRevision"
      ],
      "title": "ActorContract",
      "type": "object"
    },
    "AssertionSpec": {
      "additionalProperties": false,
      "description": "Immutable Oracle reference derived from an assertion graph node.",
      "properties": {
        "assertionId": {
          "title": "Assertionid",
          "type": "string"
        },
        "nodeId": {
          "title": "Nodeid",
          "type": "string"
        },
        "evaluatorVersionRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Evaluatorversionref",
          "type": "string"
        },
        "strength": {
          "$ref": "#/$defs/OracleStrength"
        }
      },
      "required": [
        "assertionId",
        "nodeId",
        "evaluatorVersionRef",
        "strength"
      ],
      "title": "AssertionSpec",
      "type": "object"
    },
    "BrowserContextRestoreEnvelope": {
      "additionalProperties": false,
      "description": "Encrypted session descriptor safe to carry through Temporal history.",
      "properties": {
        "schemaVersion": {
          "const": "atlas.browser-context-restore-envelope/0.1",
          "default": "atlas.browser-context-restore-envelope/0.1",
          "title": "Schemaversion",
          "type": "string"
        },
        "actorSlot": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,159}$",
          "title": "Actorslot",
          "type": "string"
        },
        "browserContextRef": {
          "pattern": "^bctx_[A-Za-z0-9_-]{32,200}$",
          "title": "Browsercontextref",
          "type": "string"
        },
        "algorithm": {
          "const": "AES-256-GCM",
          "default": "AES-256-GCM",
          "title": "Algorithm",
          "type": "string"
        },
        "keyVersion": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,159}$",
          "title": "Keyversion",
          "type": "string"
        },
        "nonce": {
          "pattern": "^[A-Za-z0-9_-]+={0,2}$",
          "title": "Nonce",
          "type": "string"
        },
        "ciphertext": {
          "pattern": "^[A-Za-z0-9_-]+={0,2}$",
          "title": "Ciphertext",
          "type": "string"
        },
        "expiresAt": {
          "format": "date-time",
          "title": "Expiresat",
          "type": "string"
        }
      },
      "required": [
        "actorSlot",
        "browserContextRef",
        "keyVersion",
        "nonce",
        "ciphertext",
        "expiresAt"
      ],
      "title": "BrowserContextRestoreEnvelope",
      "type": "object"
    },
    "BrowserExecutionProfile": {
      "additionalProperties": false,
      "description": "Reviewed browser binary and deterministic locale settings.",
      "properties": {
        "engine": {
          "const": "chromium",
          "default": "chromium",
          "title": "Engine",
          "type": "string"
        },
        "revision": {
          "maxLength": 160,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{1,255}$",
          "title": "Revision",
          "type": "string"
        },
        "viewport": {
          "$ref": "#/$defs/Viewport"
        },
        "locale": {
          "maxLength": 35,
          "minLength": 2,
          "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$",
          "title": "Locale",
          "type": "string"
        },
        "timezone": {
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_+./-]+$",
          "title": "Timezone",
          "type": "string"
        }
      },
      "required": [
        "revision",
        "viewport",
        "locale",
        "timezone"
      ],
      "title": "BrowserExecutionProfile",
      "type": "object"
    },
    "EdgeMapping": {
      "description": "Supported edge mapping operations for the v0.1 contract.",
      "enum": [
        "direct"
      ],
      "title": "EdgeMapping",
      "type": "string"
    },
    "EvidencePolicy": {
      "additionalProperties": false,
      "description": "Environment-independent evidence requirements.",
      "properties": {
        "trace": {
          "default": true,
          "title": "Trace",
          "type": "boolean"
        },
        "screenshots": {
          "default": "critical-actions",
          "enum": [
            "critical-actions",
            "assertions",
            "all"
          ],
          "title": "Screenshots",
          "type": "string"
        },
        "retainSuccessDays": {
          "default": 7,
          "maximum": 90,
          "minimum": 1,
          "title": "Retainsuccessdays",
          "type": "integer"
        },
        "retainFailureDays": {
          "default": 30,
          "maximum": 365,
          "minimum": 1,
          "title": "Retainfailuredays",
          "type": "integer"
        }
      },
      "title": "EvidencePolicy",
      "type": "object"
    },
    "ExecutionActorBinding": {
      "additionalProperties": false,
      "description": "Exact role, lease fence, and opaque login session for one actor slot.",
      "properties": {
        "actorSlot": {
          "maxLength": 80,
          "minLength": 2,
          "pattern": "^[A-Za-z_][A-Za-z0-9_.-]{1,79}$",
          "title": "Actorslot",
          "type": "string"
        },
        "roleId": {
          "format": "uuid",
          "title": "Roleid",
          "type": "string"
        },
        "roleKey": {
          "maxLength": 80,
          "minLength": 2,
          "pattern": "^[a-z][a-z0-9._-]{1,79}$",
          "title": "Rolekey",
          "type": "string"
        },
        "roleRevision": {
          "minimum": 1,
          "title": "Rolerevision",
          "type": "integer"
        },
        "accountLeaseId": {
          "format": "uuid",
          "title": "Accountleaseid",
          "type": "string"
        },
        "accountHandle": {
          "pattern": "^ah_[A-Za-z0-9_-]{16,128}$",
          "title": "Accounthandle",
          "type": "string"
        },
        "fencingToken": {
          "minimum": 1,
          "title": "Fencingtoken",
          "type": "integer"
        },
        "browserContextRef": {
          "pattern": "^bctx_[A-Za-z0-9_-]{32,200}$",
          "title": "Browsercontextref",
          "type": "string"
        }
      },
      "required": [
        "actorSlot",
        "roleId",
        "roleKey",
        "roleRevision",
        "accountLeaseId",
        "accountHandle",
        "fencingToken",
        "browserContextRef"
      ],
      "title": "ExecutionActorBinding",
      "type": "object"
    },
    "ExecutionContract": {
      "additionalProperties": false,
      "description": "Complete immutable binding consumed by one DebugRun browser execution.",
      "properties": {
        "schemaVersion": {
          "const": "atlas.execution-contract/0.1",
          "default": "atlas.execution-contract/0.1",
          "title": "Schemaversion",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "tenantId": {
          "format": "uuid",
          "title": "Tenantid",
          "type": "string"
        },
        "projectId": {
          "format": "uuid",
          "title": "Projectid",
          "type": "string"
        },
        "environmentId": {
          "format": "uuid",
          "title": "Environmentid",
          "type": "string"
        },
        "debugRunId": {
          "format": "uuid",
          "title": "Debugrunid",
          "type": "string"
        },
        "testCaseId": {
          "format": "uuid",
          "title": "Testcaseid",
          "type": "string"
        },
        "semanticRevision": {
          "minimum": 1,
          "title": "Semanticrevision",
          "type": "integer"
        },
        "testIrDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Testirdigest",
          "type": "string"
        },
        "planDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Plandigest",
          "type": "string"
        },
        "compiledDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Compileddigest",
          "type": "string"
        },
        "actors": {
          "items": {
            "$ref": "#/$defs/ExecutionActorBinding"
          },
          "maxItems": 8,
          "minItems": 1,
          "title": "Actors",
          "type": "array"
        },
        "fixture": {
          "$ref": "#/$defs/FixtureExecutionBinding"
        },
        "browser": {
          "$ref": "#/$defs/BrowserExecutionProfile"
        },
        "model": {
          "$ref": "#/$defs/ModelExecutionProfile"
        },
        "tools": {
          "$ref": "#/$defs/ToolExecutionProfile"
        },
        "workerIdentity": {
          "maxLength": 160,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,159}$",
          "title": "Workeridentity",
          "type": "string"
        },
        "executionDeadline": {
          "format": "date-time",
          "title": "Executiondeadline",
          "type": "string"
        },
        "createdAt": {
          "format": "date-time",
          "title": "Createdat",
          "type": "string"
        },
        "contentDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Contentdigest",
          "type": "string"
        }
      },
      "required": [
        "id",
        "tenantId",
        "projectId",
        "environmentId",
        "debugRunId",
        "testCaseId",
        "semanticRevision",
        "testIrDigest",
        "planDigest",
        "compiledDigest",
        "actors",
        "fixture",
        "browser",
        "model",
        "tools",
        "workerIdentity",
        "executionDeadline",
        "createdAt",
        "contentDigest"
      ],
      "title": "ExecutionContract",
      "type": "object"
    },
    "FixtureContract": {
      "additionalProperties": false,
      "description": "Exact published fixture blueprint consumed by the case.",
      "properties": {
        "blueprintVersionId": {
          "format": "uuid",
          "title": "Blueprintversionid",
          "type": "string"
        },
        "blueprintVersionRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Blueprintversionref",
          "type": "string"
        },
        "contentDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Contentdigest",
          "type": "string"
        },
        "requiredExports": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 64,
          "title": "Requiredexports",
          "type": "object"
        }
      },
      "required": [
        "blueprintVersionId",
        "blueprintVersionRef",
        "contentDigest"
      ],
      "title": "FixtureContract",
      "type": "object"
    },
    "FixtureExecutionBinding": {
      "additionalProperties": false,
      "description": "Exact ready FixtureRun and immutable export manifest binding.",
      "properties": {
        "fixtureRunId": {
          "format": "uuid",
          "title": "Fixturerunid",
          "type": "string"
        },
        "blueprintVersionId": {
          "format": "uuid",
          "title": "Blueprintversionid",
          "type": "string"
        },
        "blueprintVersionRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Blueprintversionref",
          "type": "string"
        },
        "blueprintContentDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Blueprintcontentdigest",
          "type": "string"
        },
        "fixturePlanDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Fixtureplandigest",
          "type": "string"
        },
        "fixtureManifestDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Fixturemanifestdigest",
          "type": "string"
        }
      },
      "required": [
        "fixtureRunId",
        "blueprintVersionId",
        "blueprintVersionRef",
        "blueprintContentDigest",
        "fixturePlanDigest",
        "fixtureManifestDigest"
      ],
      "title": "FixtureExecutionBinding",
      "type": "object"
    },
    "JsonValue": {},
    "ModelExecutionProfile": {
      "additionalProperties": false,
      "description": "Frozen model and Prompt identities without provider secrets.",
      "properties": {
        "modelProfileRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Modelprofileref",
          "type": "string"
        },
        "promptBundleRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Promptbundleref",
          "type": "string"
        },
        "reasoningPolicyRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Reasoningpolicyref",
          "type": "string"
        }
      },
      "required": [
        "modelProfileRef",
        "promptBundleRef",
        "reasoningPolicyRef"
      ],
      "title": "ModelExecutionProfile",
      "type": "object"
    },
    "OracleStrength": {
      "description": "Oracle authority level.",
      "enum": [
        "hard",
        "soft",
        "diagnostic"
      ],
      "title": "OracleStrength",
      "type": "string"
    },
    "OutcomePolicy": {
      "additionalProperties": false,
      "description": "Independent Oracle authority requirements.",
      "properties": {
        "requireHardOracle": {
          "default": true,
          "title": "Requirehardoracle",
          "type": "boolean"
        },
        "evidenceIncompleteBlocksPass": {
          "default": true,
          "title": "Evidenceincompleteblockspass",
          "type": "boolean"
        },
        "agentMayDecidePass": {
          "const": false,
          "default": false,
          "title": "Agentmaydecidepass",
          "type": "boolean"
        }
      },
      "title": "OutcomePolicy",
      "type": "object"
    },
    "PlanNodeRef": {
      "additionalProperties": false,
      "properties": {
        "nodeId": {
          "title": "Nodeid",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "versionRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Versionref",
          "type": "string"
        },
        "executionLevel": {
          "minimum": 0,
          "title": "Executionlevel",
          "type": "integer"
        }
      },
      "required": [
        "nodeId",
        "kind",
        "versionRef",
        "executionLevel"
      ],
      "title": "PlanNodeRef",
      "type": "object"
    },
    "PlanTemplate": {
      "additionalProperties": false,
      "description": "Environment-independent plan compiled from one exact Test IR.",
      "properties": {
        "schemaVersion": {
          "const": "atlas.plan-template/0.1",
          "default": "atlas.plan-template/0.1",
          "title": "Schemaversion",
          "type": "string"
        },
        "testCaseId": {
          "format": "uuid",
          "title": "Testcaseid",
          "type": "string"
        },
        "semanticRevision": {
          "minimum": 0,
          "title": "Semanticrevision",
          "type": "integer"
        },
        "testIrDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Testirdigest",
          "type": "string"
        },
        "graphDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Graphdigest",
          "type": "string"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/PlanNodeRef"
          },
          "title": "Nodes",
          "type": "array"
        },
        "executionLevels": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Executionlevels",
          "type": "array"
        },
        "requiredFeatures": {
          "items": {
            "type": "string"
          },
          "title": "Requiredfeatures",
          "type": "array"
        },
        "planDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Plandigest",
          "type": "string"
        }
      },
      "required": [
        "testCaseId",
        "semanticRevision",
        "testIrDigest",
        "graphDigest",
        "nodes",
        "executionLevels",
        "requiredFeatures",
        "planDigest"
      ],
      "title": "PlanTemplate",
      "type": "object"
    },
    "PortKind": {
      "description": "Port trust and scheduling category.",
      "enum": [
        "data",
        "control"
      ],
      "title": "PortKind",
      "type": "string"
    },
    "PortSpec": {
      "additionalProperties": false,
      "description": "A strongly typed node port.",
      "properties": {
        "key": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z_][A-Za-z0-9_.-]{0,127}$",
          "title": "Key",
          "type": "string"
        },
        "semanticType": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Semantictype",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/PortKind",
          "default": "data"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "sensitive": {
          "default": false,
          "title": "Sensitive",
          "type": "boolean"
        }
      },
      "required": [
        "key",
        "semanticType"
      ],
      "title": "PortSpec",
      "type": "object"
    },
    "RecoveryPolicy": {
      "additionalProperties": false,
      "description": "Bounded retry and recovery policy compiled into a plan.",
      "properties": {
        "maxUnitAttempts": {
          "default": 1,
          "maximum": 3,
          "minimum": 1,
          "title": "Maxunitattempts",
          "type": "integer"
        },
        "retryBrowserCrash": {
          "default": false,
          "title": "Retrybrowsercrash",
          "type": "boolean"
        },
        "retryUnknownSideEffect": {
          "default": false,
          "title": "Retryunknownsideeffect",
          "type": "boolean"
        }
      },
      "title": "RecoveryPolicy",
      "type": "object"
    },
    "SourceRequirementRef": {
      "additionalProperties": false,
      "description": "Digest-only link to one untrusted requirement source anchor.",
      "properties": {
        "documentId": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Documentid",
          "type": "string"
        },
        "documentVersion": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Documentversion",
          "type": "string"
        },
        "contentDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Contentdigest",
          "type": "string"
        },
        "anchor": {
          "maxLength": 320,
          "minLength": 1,
          "title": "Anchor",
          "type": "string"
        },
        "excerptDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Excerptdigest",
          "type": "string"
        }
      },
      "required": [
        "documentId",
        "documentVersion",
        "contentDigest",
        "anchor",
        "excerptDigest"
      ],
      "title": "SourceRequirementRef",
      "type": "object"
    },
    "SurfaceRef": {
      "additionalProperties": false,
      "description": "Exact published semantic page contract reference.",
      "properties": {
        "surfaceKey": {
          "maxLength": 160,
          "minLength": 3,
          "pattern": "^[A-Za-z][A-Za-z0-9._:-]{1,159}$",
          "title": "Surfacekey",
          "type": "string"
        },
        "versionRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Versionref",
          "type": "string"
        },
        "contentDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Contentdigest",
          "type": "string"
        }
      },
      "required": [
        "surfaceKey",
        "versionRef",
        "contentDigest"
      ],
      "title": "SurfaceRef",
      "type": "object"
    },
    "TestIR": {
      "additionalProperties": false,
      "description": "Strongly typed, environment-independent Test IR v0.2.",
      "properties": {
        "schemaVersion": {
          "const": "atlas.test-ir/0.2",
          "default": "atlas.test-ir/0.2",
          "title": "Schemaversion",
          "type": "string"
        },
        "testCaseId": {
          "format": "uuid",
          "title": "Testcaseid",
          "type": "string"
        },
        "semanticRevision": {
          "minimum": 0,
          "title": "Semanticrevision",
          "type": "integer"
        },
        "intentVersionRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Intentversionref",
          "type": "string"
        },
        "requirementRefs": {
          "items": {
            "$ref": "#/$defs/SourceRequirementRef"
          },
          "title": "Requirementrefs",
          "type": "array"
        },
        "actors": {
          "items": {
            "$ref": "#/$defs/ActorContract"
          },
          "title": "Actors",
          "type": "array"
        },
        "fixture": {
          "$ref": "#/$defs/FixtureContract"
        },
        "workflow": {
          "$ref": "#/$defs/WorkflowGraph"
        },
        "surfaces": {
          "items": {
            "$ref": "#/$defs/SurfaceRef"
          },
          "title": "Surfaces",
          "type": "array"
        },
        "variables": {
          "additionalProperties": {
            "$ref": "#/$defs/ValueSource"
          },
          "title": "Variables",
          "type": "object"
        },
        "assertions": {
          "items": {
            "$ref": "#/$defs/AssertionSpec"
          },
          "title": "Assertions",
          "type": "array"
        },
        "evidencePolicy": {
          "$ref": "#/$defs/EvidencePolicy"
        },
        "recoveryPolicy": {
          "$ref": "#/$defs/RecoveryPolicy"
        },
        "outcomePolicy": {
          "$ref": "#/$defs/OutcomePolicy"
        },
        "requiredFeatures": {
          "items": {
            "type": "string"
          },
          "title": "Requiredfeatures",
          "type": "array"
        },
        "executionLevels": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Executionlevels",
          "type": "array"
        },
        "contentDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
