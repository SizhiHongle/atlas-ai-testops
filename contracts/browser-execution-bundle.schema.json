    "ToolExecutionProfile": {
      "additionalProperties": false,
      "description": "Frozen tool catalog, MCP manifests, and policy bundle digests.",
      "properties": {
        "toolCatalogRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Toolcatalogref",
          "type": "string"
        },
        "mcpServerManifestDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Mcpservermanifestdigest",
          "type": "string"
        },
        "toolSchemaDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Toolschemadigest",
          "type": "string"
        },
        "policyBundleRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Policybundleref",
          "type": "string"
        },
        "policyDigest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Policydigest",
          "type": "string"
        }
      },
      "required": [
        "toolCatalogRef",
        "mcpServerManifestDigest",
        "toolSchemaDigest",
        "policyBundleRef",
        "policyDigest"
      ],
      "title": "ToolExecutionProfile",
      "type": "object"
    },
    "ValueSource": {
      "additionalProperties": false,
      "description": "Structured value source without expressions or dynamic evaluation.",
      "properties": {
        "kind": {
          "$ref": "#/$defs/ValueSourceKind"
        },
        "reference": {
          "anyOf": [
            {
              "maxLength": 320,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference"
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/JsonValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "kind"
      ],
      "title": "ValueSource",
      "type": "object"
    },
    "ValueSourceKind": {
      "description": "Only four deterministic value sources are accepted by Test IR.",
      "enum": [
        "FIXTURE",
        "ACTOR",
        "RUN",
        "LITERAL"
      ],
      "title": "ValueSourceKind",
      "type": "string"
    },
    "Viewport": {
      "additionalProperties": false,
      "description": "Frozen browser viewport used by one execution.",
      "properties": {
        "width": {
          "maximum": 7680,
          "minimum": 320,
          "title": "Width",
          "type": "integer"
