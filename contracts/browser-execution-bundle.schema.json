        "requirementRefs",
        "actors",
        "fixture",
        "workflow",
        "surfaces",
        "variables",
        "assertions",
        "evidencePolicy",
        "recoveryPolicy",
        "outcomePolicy",
        "requiredFeatures",
        "executionLevels",
