{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.test/contracts/workflow-patch/0.1/schema.json",
  "$defs": {
    "AddEdgeOperation": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "ADD_EDGE",
          "default": "ADD_EDGE",
          "title": "Op",
          "type": "string"
        },
        "edge": {
          "$ref": "#/$defs/WorkflowEdge"
        }
      },
      "required": [
        "edge"
      ],
      "title": "AddEdgeOperation",
      "type": "object"
    },
    "AddNodeOperation": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "ADD_NODE",
          "default": "ADD_NODE",
          "title": "Op",
          "type": "string"
        },
        "node": {
          "$ref": "#/$defs/WorkflowNode"
        }
      },
      "required": [
        "node"
      ],
      "title": "AddNodeOperation",
      "type": "object"
    },
    "DraftAuthor": {
      "description": "Actor that last changed a Workflow Draft.",
      "enum": [
        "ai",
        "human"
      ],
      "title": "DraftAuthor",
      "type": "string"
    },
    "EdgeMapping": {
      "description": "Supported edge mapping operations for the v0.1 contract.",
      "enum": [
        "direct"
      ],
      "title": "EdgeMapping",
      "type": "string"
    },
    "JsonValue": {},
    "OracleStrength": {
      "description": "Oracle authority level.",
      "enum": [
        "hard",
        "soft",
        "diagnostic"
      ],
      "title": "OracleStrength",
      "type": "string"
    },
    "PortKind": {
      "description": "Port trust and scheduling category.",
      "enum": [
        "data",
        "control"
      ],
      "title": "PortKind",
      "type": "string"
    },
    "PortSpec": {
      "additionalProperties": false,
      "description": "A strongly typed node port.",
      "properties": {
        "key": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z_][A-Za-z0-9_.-]{0,127}$",
          "title": "Key",
          "type": "string"
        },
        "semanticType": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Semantictype",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/PortKind",
          "default": "data"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "sensitive": {
          "default": false,
          "title": "Sensitive",
          "type": "boolean"
        }
      },
      "required": [
        "key",
        "semanticType"
      ],
      "title": "PortSpec",
      "type": "object"
    },
    "RemoveEdgeOperation": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "REMOVE_EDGE",
          "default": "REMOVE_EDGE",
          "title": "Op",
          "type": "string"
        },
        "edgeId": {
          "title": "Edgeid",
          "type": "string"
        }
      },
      "required": [
        "edgeId"
      ],
      "title": "RemoveEdgeOperation",
      "type": "object"
    },
    "RemoveNodeOperation": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "REMOVE_NODE",
          "default": "REMOVE_NODE",
          "title": "Op",
          "type": "string"
        },
        "nodeId": {
          "title": "Nodeid",
          "type": "string"
        }
      },
      "required": [
        "nodeId"
      ],
      "title": "RemoveNodeOperation",
      "type": "object"
    },
    "ReplaceEdgeOperation": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "REPLACE_EDGE",
          "default": "REPLACE_EDGE",
          "title": "Op",
          "type": "string"
        },
        "edgeId": {
          "title": "Edgeid",
          "type": "string"
        },
        "edge": {
          "$ref": "#/$defs/WorkflowEdge"
        }
      },
      "required": [
        "edgeId",
        "edge"
      ],
      "title": "ReplaceEdgeOperation",
      "type": "object"
    },
    "ReplaceNodeOperation": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "const": "REPLACE_NODE",
          "default": "REPLACE_NODE",
          "title": "Op",
          "type": "string"
        },
        "nodeId": {
          "title": "Nodeid",
          "type": "string"
        },
        "node": {
          "$ref": "#/$defs/WorkflowNode"
        }
      },
      "required": [
        "nodeId",
        "node"
      ],
      "title": "ReplaceNodeOperation",
      "type": "object"
    },
    "WorkflowEdge": {
      "additionalProperties": false,
      "description": "A direct typed mapping between two node ports.",
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,127}$",
          "title": "Id",
          "type": "string"
        },
        "sourceNodeId": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,127}$",
          "title": "Sourcenodeid",
          "type": "string"
        },
        "sourcePort": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z_][A-Za-z0-9_.-]{0,127}$",
          "title": "Sourceport",
          "type": "string"
        },
        "targetNodeId": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,127}$",
          "title": "Targetnodeid",
          "type": "string"
        },
        "targetPort": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z_][A-Za-z0-9_.-]{0,127}$",
          "title": "Targetport",
          "type": "string"
        },
        "semanticType": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Semantictype",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/PortKind",
          "default": "data"
        },
        "mapping": {
          "$ref": "#/$defs/EdgeMapping",
          "default": "direct"
        }
      },
      "required": [
        "id",
        "sourceNodeId",
        "sourcePort",
        "targetNodeId",
        "targetPort",
        "semanticType"
      ],
      "title": "WorkflowEdge",
      "type": "object"
    },
    "WorkflowNode": {
      "additionalProperties": false,
      "description": "A published node reference inside an authoring graph.",
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,127}$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "versionRef": {
          "maxLength": 256,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
          "title": "Versionref",
          "type": "string"
        },
        "phase": {
          "$ref": "#/$defs/WorkflowPhase"
        },
        "inputPorts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PortSpec"
          },
          "title": "Inputports",
          "type": "array"
        },
        "outputPorts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PortSpec"
          },
          "title": "Outputports",
          "type": "array"
        },
        "params": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Params",
          "type": "object"
        },
        "terminal": {
          "default": false,
          "title": "Terminal",
          "type": "boolean"
        },
        "oracleStrength": {
          "anyOf": [
            {
              "$ref": "#/$defs/OracleStrength"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "id",
        "kind",
        "versionRef",
        "phase"
      ],
      "title": "WorkflowNode",
      "type": "object"
    },
    "WorkflowPhase": {
      "description": "Supported deterministic workflow phases.",
      "enum": [
        "setup",
        "identity",
        "execute",
        "assert",
        "cleanup"
      ],
      "title": "WorkflowPhase",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Atomic semantic edit shared by AI and human authoring.",
  "properties": {
    "patchId": {
      "format": "uuid",
      "title": "Patchid",
      "type": "string"
    },
    "clientMutationId": {
      "maxLength": 200,
      "minLength": 8,
      "title": "Clientmutationid",
      "type": "string"
    },
    "baseSemanticRevision": {
      "minimum": 0,
      "title": "Basesemanticrevision",
      "type": "integer"
    },
    "source": {
      "$ref": "#/$defs/DraftAuthor"
    },
    "operations": {
      "items": {
        "discriminator": {
          "mapping": {
            "ADD_EDGE": "#/$defs/AddEdgeOperation",
            "ADD_NODE": "#/$defs/AddNodeOperation",
            "REMOVE_EDGE": "#/$defs/RemoveEdgeOperation",
            "REMOVE_NODE": "#/$defs/RemoveNodeOperation",
            "REPLACE_EDGE": "#/$defs/ReplaceEdgeOperation",
            "REPLACE_NODE": "#/$defs/ReplaceNodeOperation"
          },
          "propertyName": "op"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/AddNodeOperation"
          },
          {
            "$ref": "#/$defs/ReplaceNodeOperation"
          },
          {
            "$ref": "#/$defs/RemoveNodeOperation"
          },
          {
            "$ref": "#/$defs/AddEdgeOperation"
          },
          {
            "$ref": "#/$defs/ReplaceEdgeOperation"
          },
          {
            "$ref": "#/$defs/RemoveEdgeOperation"
          }
        ]
      },
      "maxItems": 128,
      "minItems": 1,
      "title": "Operations",
      "type": "array"
    },
    "rationaleSummary": {
      "anyOf": [
        {
          "maxLength": 1000,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rationalesummary"
    }
  },
  "required": [
    "patchId",
    "clientMutationId",
    "baseSemanticRevision",
    "source",
    "operations"
  ],
  "title": "WorkflowPatch",
  "type": "object"
}
