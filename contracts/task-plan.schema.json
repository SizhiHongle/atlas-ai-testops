{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.test/contracts/task-plan/0.1/schema.json",
  "$defs": {
    "TaskPlanStatus": {
      "description": "Lifecycle of a stable TaskPlan identity.",
      "enum": [
        "ACTIVE",
        "ARCHIVED"
      ],
      "title": "TaskPlanStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Stable identity for a versioned reusable task plan.",
  "properties": {
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "tenantId": {
      "format": "uuid",
      "title": "Tenantid",
      "type": "string"
    },
    "projectId": {
      "format": "uuid",
      "title": "Projectid",
      "type": "string"
    },
    "taskKey": {
      "maxLength": 160,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+){0,7}$",
      "title": "Taskkey",
      "type": "string"
    },
    "name": {
      "maxLength": 160,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/TaskPlanStatus"
    },
    "createdBy": {
      "format": "uuid",
      "title": "Createdby",
      "type": "string"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "createdAt": {
      "format": "date-time",
      "title": "Createdat",
      "type": "string"
    },
    "updatedAt": {
      "format": "date-time",
      "title": "Updatedat",
      "type": "string"
    }
  },
  "required": [
    "id",
    "tenantId",
    "projectId",
    "taskKey",
    "name",
    "status",
    "createdBy",
    "revision",
    "createdAt",
    "updatedAt"
  ],
  "title": "TaskPlan",
  "type": "object"
}
