{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.test/contracts/task-plan-version/0.1/schema.json",
  "$defs": {
    "CaseExecutionProfileRef": {
      "additionalProperties": false,
      "description": "Typed immutable reference slots for one pinned CaseVersion.",
      "properties": {
        "caseVersionId": {
          "format": "uuid",
          "title": "Caseversionid",
          "type": "string"
        },
        "executionProfileVersionId": {
          "format": "uuid",
          "title": "Executionprofileversionid",
          "type": "string"
        },
        "fixtureBlueprintVersionId": {
          "format": "uuid",
          "title": "Fixtureblueprintversionid",
          "type": "string"
        }
      },
      "required": [
        "caseVersionId",
        "executionProfileVersionId",
        "fixtureBlueprintVersionId"
      ],
      "title": "CaseExecutionProfileRef",
      "type": "object"
    },
    "TaskMatrixDefinition": {
      "additionalProperties": false,
      "description": "Explicit V1 matrix axes without executable expressions.",
      "properties": {
        "environmentIds": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "maxItems": 1000,
          "minItems": 1,
          "title": "Environmentids",
          "type": "array"
        },
        "browserProfileVersionIds": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "maxItems": 1000,
          "minItems": 1,
          "title": "Browserprofileversionids",
          "type": "array"
        },
        "identityProfileVersionIds": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "maxItems": 1000,
          "minItems": 1,
          "title": "Identityprofileversionids",
          "type": "array"
        },
        "dataProfileVersionIds": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "maxItems": 1000,
          "minItems": 1,
          "title": "Dataprofileversionids",
          "type": "array"
        }
      },
      "required": [
        "environmentIds",
        "browserProfileVersionIds",
        "identityProfileVersionIds",
        "dataProfileVersionIds"
      ],
      "title": "TaskMatrixDefinition",
      "type": "object"
    },
    "TaskProfileRefs": {
      "additionalProperties": false,
      "description": "Structured per-case profiles with no user-provided code or expressions.",
      "properties": {
        "caseProfiles": {
          "items": {
            "$ref": "#/$defs/CaseExecutionProfileRef"
          },
          "maxItems": 100000,
          "minItems": 1,
          "title": "Caseprofiles",
          "type": "array"
        }
      },
      "required": [
        "caseProfiles"
      ],
      "title": "TaskProfileRefs",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Published immutable TaskPlan snapshot consumed only by exact ID.",
  "properties": {
    "schemaVersion": {
      "const": "atlas.task-plan/0.1",
      "default": "atlas.task-plan/0.1",
      "title": "Schemaversion",
      "type": "string"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "tenantId": {
      "format": "uuid",
      "title": "Tenantid",
      "type": "string"
    },
    "projectId": {
      "format": "uuid",
      "title": "Projectid",
      "type": "string"
    },
    "taskPlanId": {
      "format": "uuid",
      "title": "Taskplanid",
      "type": "string"
    },
    "version": {
      "maxLength": 80,
      "minLength": 5,
      "pattern": "^(?:0|[1-9][0-9]*)[.](?:0|[1-9][0-9]*)[.](?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:[+][0-9A-Za-z.-]+)?$",
      "title": "Version",
      "type": "string"
    },
    "versionRef": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Versionref",
      "type": "string"
    },
    "pinnedCaseVersionIds": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "maxItems": 100000,
      "minItems": 1,
      "title": "Pinnedcaseversionids",
      "type": "array"
    },
    "matrix": {
      "$ref": "#/$defs/TaskMatrixDefinition"
    },
    "profileRefs": {
      "$ref": "#/$defs/TaskProfileRefs"
    },
    "policyDigests": {
      "additionalProperties": false,
      "maxProperties": 64,
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_.-]{1,127}$": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "title": "Policydigests",
      "type": "object"
    },
    "contentDigest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Contentdigest",
      "type": "string"
    },
    "publishedBy": {
      "format": "uuid",
      "title": "Publishedby",
      "type": "string"
    },
    "publishedAt": {
      "format": "date-time",
      "title": "Publishedat",
      "type": "string"
    },
    "revision": {
      "const": 1,
      "title": "Revision",
      "type": "integer"
    },
    "createdAt": {
      "format": "date-time",
      "title": "Createdat",
      "type": "string"
    },
    "updatedAt": {
      "format": "date-time",
      "title": "Updatedat",
      "type": "string"
    }
  },
  "required": [
    "id",
    "tenantId",
    "projectId",
    "taskPlanId",
    "version",
    "versionRef",
    "pinnedCaseVersionIds",
    "matrix",
    "profileRefs",
    "policyDigests",
    "contentDigest",
    "publishedBy",
    "publishedAt",
    "revision",
    "createdAt",
    "updatedAt"
  ],
  "title": "TaskPlanVersion",
  "type": "object"
}
