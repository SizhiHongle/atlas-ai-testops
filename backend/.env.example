ATLAS_ENVIRONMENT=local
ATLAS_LOG_LEVEL=INFO
ATLAS_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ATLAS_DOCS_ENABLED=true
ATLAS_DATABASE_URL=postgresql://atlas_app:atlas_app@127.0.0.1:5432/atlas
ATLAS_DATABASE_POOL_MIN_SIZE=1
ATLAS_DATABASE_POOL_MAX_SIZE=10
ATLAS_DATABASE_CONNECT_TIMEOUT_SECONDS=5
ATLAS_DATABASE_STATEMENT_TIMEOUT_MS=10000
ATLAS_DEBUG_LIVE_POLL_INTERVAL_MS=500
ATLAS_DEBUG_LIVE_HEARTBEAT_SECONDS=10
ATLAS_DEBUG_LIVE_MAX_CONNECTION_SECONDS=30
ATLAS_DEBUG_LIVE_BATCH_SIZE=100
ATLAS_DEBUG_LIVE_MAXIMUM_CONNECTIONS=64
ATLAS_SECRET_GRANT_TTL_SECONDS=60
ATLAS_ACCOUNT_HEALTH_VERIFICATION_TIMEOUT_SECONDS=30
ATLAS_ACCOUNT_HEALTH_ATTEMPT_TTL_SECONDS=120
ATLAS_TEMPORAL_ADDRESS=127.0.0.1:7233
ATLAS_TEMPORAL_NAMESPACE=default
ATLAS_TEMPORAL_TASK_QUEUE=atlas-control
ATLAS_TASK_WORKER_ENABLED=false
ATLAS_TASK_RUN_TASK_QUEUE=atlas-task-run
ATLAS_TASK_ATTEMPT_TASK_QUEUE=atlas-unit-attempt
ATLAS_TASK_RUN_WORKER_MAX_CONCURRENCY=8
ATLAS_TASK_ATTEMPT_WORKER_MAX_CONCURRENCY=8
ATLAS_TASK_SCHEDULE_WORKER_ENABLED=false
ATLAS_TASK_SCHEDULE_TASK_QUEUE=atlas-task-schedule
ATLAS_TASK_SCHEDULE_WORKER_MAX_CONCURRENCY=8

# Task Worker production execution adapter. Both values are required when the
# CLI Task Worker is enabled. HTTPS is mandatory in staging and production.
# ATLAS_TASK_EXECUTION_API_BASE_URL=https://task-executor.internal
# Generate a key with: openssl rand -base64 32
# ATLAS_TASK_EXECUTION_HMAC_KEY_BASE64=<shared-rotated-hmac-key>
# ATLAS_TASK_EXECUTION_WORKER_IDENTITY=task-worker
# ATLAS_TASK_EXECUTION_HTTP_TIMEOUT_SECONDS=120
# ATLAS_TASK_EXECUTION_CLOCK_SKEW_SECONDS=30
# ATLAS_TASK_EXECUTION_RESPONSE_MAXIMUM_BYTES=16384

ATLAS_AUTH_SESSION_DISPATCH_ENABLED=false
ATLAS_AUTH_SESSION_TASK_QUEUE=atlas-auth-session
ATLAS_AUTH_SESSION_WORKFLOW_TIMEOUT_SECONDS=90
ATLAS_AUTH_SESSION_TTL_SECONDS=900
ATLAS_AUTH_SESSION_CREATION_TIMEOUT_SECONDS=45
ATLAS_AUTH_SESSION_ATTEMPT_TTL_SECONDS=120
ATLAS_AUTH_SESSION_MANUAL_TICKET_TTL_SECONDS=600
ATLAS_AUTH_SESSION_WORKER_MAX_CONCURRENCY=4
ATLAS_SESSION_JANITOR_CLAIM_TTL_SECONDS=120
ATLAS_FIXTURE_DISPATCH_ENABLED=false
ATLAS_FIXTURE_TASK_QUEUE=atlas-fixture
ATLAS_FIXTURE_ACTIVITY_TIMEOUT_SECONDS=330
ATLAS_FIXTURE_CLEANUP_GRACE_SECONDS=900
ATLAS_FIXTURE_WORKER_MAX_CONCURRENCY=8

# Auth Session Worker only. Keep these variables out of the API deployment.
# ATLAS_SESSION_OBJECT_STORE_ENDPOINT=127.0.0.1:9000
# ATLAS_SESSION_OBJECT_STORE_ACCESS_KEY=atlas_minio
# ATLAS_SESSION_OBJECT_STORE_SECRET_KEY=atlas_minio_password
# ATLAS_SESSION_OBJECT_STORE_BUCKET=atlas-session-artifacts
# ATLAS_SESSION_OBJECT_STORE_SECURE=false
# ATLAS_SESSION_OBJECT_STORE_CREATE_BUCKET=true
# Generate a local-only key with: openssl rand -base64 32
# ATLAS_SESSION_ARTIFACT_AES_KEY_BASE64=<base64-encoded-32-byte-key>
# ATLAS_SESSION_ARTIFACT_KEY_VERSION=local-v1

# Evidence API and Browser Worker. Use separate write/read credentials in production.
# ATLAS_EVIDENCE_OBJECT_STORE_ENDPOINT=127.0.0.1:9000
# ATLAS_EVIDENCE_OBJECT_STORE_ACCESS_KEY=atlas_minio
# ATLAS_EVIDENCE_OBJECT_STORE_SECRET_KEY=atlas_minio_password
# ATLAS_EVIDENCE_OBJECT_STORE_BUCKET=atlas-evidence-artifacts
# ATLAS_EVIDENCE_OBJECT_STORE_SECURE=false
# ATLAS_EVIDENCE_OBJECT_STORE_CREATE_BUCKET=true
# ATLAS_EVIDENCE_OBJECT_STORE_CONNECT_TIMEOUT_SECONDS=3
# ATLAS_EVIDENCE_OBJECT_STORE_READ_TIMEOUT_SECONDS=15
# ATLAS_EVIDENCE_OBJECT_STORE_MAXIMUM_CONCURRENCY=8
# ATLAS_EVIDENCE_OBJECT_STORE_MAXIMUM_RETRIES=1
# ATLAS_EVIDENCE_READ_GRANT_TTL_SECONDS=60
# ATLAS_EVIDENCE_READ_GRANT_MAX_READS=8
# ATLAS_EVIDENCE_READ_MAXIMUM_BYTES=67108864
# Browser Worker-only capture bounds.
# ATLAS_EVIDENCE_CAPTURE_MAXIMUM_RAW_BYTES=33554432
# ATLAS_EVIDENCE_CAPTURE_MAXIMUM_PIXELS=33177600
