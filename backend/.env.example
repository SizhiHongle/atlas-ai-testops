ATLAS_ENVIRONMENT=local
ATLAS_LOG_LEVEL=INFO
ATLAS_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ATLAS_DOCS_ENABLED=true
ATLAS_DATABASE_URL=postgresql://atlas_app:atlas_app@127.0.0.1:5432/atlas
ATLAS_DATABASE_POOL_MIN_SIZE=1
ATLAS_DATABASE_POOL_MAX_SIZE=10
ATLAS_DATABASE_CONNECT_TIMEOUT_SECONDS=5
ATLAS_DATABASE_STATEMENT_TIMEOUT_MS=10000
ATLAS_SECRET_GRANT_TTL_SECONDS=60
ATLAS_ACCOUNT_HEALTH_VERIFICATION_TIMEOUT_SECONDS=30
ATLAS_ACCOUNT_HEALTH_ATTEMPT_TTL_SECONDS=120
ATLAS_TEMPORAL_ADDRESS=127.0.0.1:7233
ATLAS_TEMPORAL_NAMESPACE=default
ATLAS_TEMPORAL_TASK_QUEUE=atlas-control
ATLAS_AUTH_SESSION_DISPATCH_ENABLED=false
ATLAS_AUTH_SESSION_TASK_QUEUE=atlas-auth-session
ATLAS_AUTH_SESSION_WORKFLOW_TIMEOUT_SECONDS=90
ATLAS_AUTH_SESSION_TTL_SECONDS=900
ATLAS_AUTH_SESSION_CREATION_TIMEOUT_SECONDS=45
ATLAS_AUTH_SESSION_ATTEMPT_TTL_SECONDS=120
ATLAS_AUTH_SESSION_MANUAL_TICKET_TTL_SECONDS=600
ATLAS_AUTH_SESSION_WORKER_MAX_CONCURRENCY=4
ATLAS_SESSION_JANITOR_CLAIM_TTL_SECONDS=120

# Auth Session Worker only. Keep these variables out of the API deployment.
# ATLAS_SESSION_OBJECT_STORE_ENDPOINT=127.0.0.1:9000
# ATLAS_SESSION_OBJECT_STORE_ACCESS_KEY=atlas_minio
# ATLAS_SESSION_OBJECT_STORE_SECRET_KEY=atlas_minio_password
# ATLAS_SESSION_OBJECT_STORE_BUCKET=atlas-session-artifacts
# ATLAS_SESSION_OBJECT_STORE_SECURE=false
# ATLAS_SESSION_OBJECT_STORE_CREATE_BUCKET=true
# Generate a local-only key with: openssl rand -base64 32
# ATLAS_SESSION_ARTIFACT_AES_KEY_BASE64=<base64-encoded-32-byte-key>
# ATLAS_SESSION_ARTIFACT_KEY_VERSION=local-v1
